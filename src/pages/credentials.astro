---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import contactData from '../data/contact.json';

const professionalBodies = [
  {
    name: 'SAIOSH',
    full: 'South African Institute of Occupational Safety and Health',
    description: 'Professional body for occupational safety and health practitioners',
    members: ['Mr. Simon Moletsane', 'Ms. Khensani Kekana']
  },
  {
    name: 'SACPCMP',
    full: 'South African Council for the Project and Construction Management Professions',
    description: 'Regulatory body for construction management professionals',
    members: ['Ms. Mangale Cynthia Machethe', 'Ms. Khensani Kekana (Candidate)']
  },
  {
    name: 'SAIOH',
    full: 'South African Institute of Occupational Hygiene',
    description: 'Professional body for occupational hygiene practitioners',
    members: ['Ms. Gontse Langa']
  },
  {
    name: 'HPCSA',
    full: 'Health Professions Council of South Africa',
    description: 'Regulatory body for health professionals',
    members: ['Ms. Gontse Langa']
  },
  {
    name: 'ACPM',
    full: 'Association for Construction Project Management',
    description: 'Professional association for construction project managers',
    members: ['Team Members']
  }
];

const complianceStandards = [
  {
    title: 'Occupational Health and Safety Act',
    reference: 'Act 85 of 1993',
    description: 'Full compliance with OHS Act and all associated regulations including Construction Regulations, General Safety Regulations, and Environmental Regulations for Workplaces.',
    icon: 'shield'
  },
  {
    title: 'National Environmental Management Act',
    reference: 'NEMA',
    description: 'Comprehensive environmental compliance including waste management, air quality management, and hazardous substances regulations.',
    icon: 'leaf'
  },
  {
    title: 'Construction Regulations',
    reference: 'OHS Act Regulations',
    description: 'Specialized compliance for construction projects including safety file requirements, site establishment, and contractor management.',
    icon: 'building'
  }
];

const certifications = [
  {
    category: 'Safety Management',
    items: [
      'Diploma in Safety Management',
      'Advanced Diploma in Safety Management',
      'SAMTRAC Certification',
      'National Diploma in Safety Management'
    ]
  },
  {
    category: 'Specialized Training',
    items: [
      'Engineering & Construction Risk Management',
      'Incident Investigation Level 3',
      'Practical Safety File Development',
      'Legal Knowledge for Occupational Hygiene'
    ]
  },
  {
    category: 'Emergency Response',
    items: [
      'First Aid Level 1',
      'Basic Fire Fighter Training',
      'Emergency Preparedness Planning'
    ]
  },
  {
    category: 'Environmental Health',
    items: [
      'Environmental Health Practitioner',
      'Occupational Hygiene Assistant',
      'General Safety, Health and Environment'
    ]
  }
];

const expertise = [
  {
    area: 'Coal Mining Industry',
    description: 'Extensive experience in mining safety, ash dump operations, and coal handling'
  },
  {
    area: 'Engineering Operations',
    description: 'Infrastructure projects, electrical installations, and civil engineering'
  },
  {
    area: 'Agriculture & Chemical',
    description: 'Agricultural safety compliance and chemical company operations'
  },
  {
    area: 'Construction Projects',
    description: 'Large-scale construction, municipal infrastructure, and building projects'
  }
];
---

<Layout 
  title="Credentials & Compliance - AE SHEQ Consulting Certifications"
  description="AE SHEQ Consulting's professional registrations, certifications, and compliance standards. Registered with SAIOSH, SACPCMP, SAIOH, HPCSA, and ACPM. OHS Act and NEMA compliant."
>
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="hero-section py-20">
      <div class="container">
        <div class="max-w-3xl">
          <div class="inline-flex items-center px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full text-sm font-semibold mb-6">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Certified & Compliant
          </div>
          <h1 class="heading-display mb-6">Credentials & Compliance</h1>
          <p class="hero-subheading text-lead">
            Our professional registrations, certifications, and commitment to regulatory compliance 
            ensure the highest standards of SHEQ service delivery.
          </p>
        </div>
      </div>
    </section>

    <!-- Company Registration -->
    <section class="section bg-white">
      <div class="container">
        <div class="max-w-4xl mx-auto">
          <div class="bg-primary-50 rounded-2xl p-8 md:p-12 border-2 border-primary-200">
            <div class="flex items-start space-x-6">
              <div class="w-20 h-20 bg-primary-600 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="flex-1">
                <h2 class="heading-2 mb-4 text-primary-900">{contactData.company.name}</h2>
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <p class="text-sm font-semibold text-neutral-700 mb-1">Registration Number</p>
                    <p class="text-lg font-bold text-primary-600">{contactData.company.registration}</p>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-neutral-700 mb-1">Established</p>
                    <p class="text-lg font-bold text-primary-600">2020</p>
                  </div>
                </div>
                <p class="text-body mt-4">
                  Registered South African company providing professional SHEQ consulting services 
                  with full legal compliance and professional indemnity insurance.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Professional Body Registrations -->
    <section class="section bg-neutral-50">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="heading-2 mb-4">Professional Body Registrations</h2>
          <p class="text-lead max-w-2xl mx-auto">
            Our company and team members maintain active registrations with leading professional bodies, 
            ensuring adherence to industry standards and ethical practices.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">
          {professionalBodies.map((body) => (
            <div class="card">
              <div class="flex items-start space-x-4">
                <div class="w-16 h-16 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-8 h-8 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="font-bold text-neutral-900 mb-1">{body.name}</h3>
                  <p class="text-sm text-neutral-600 mb-3">{body.full}</p>
                  <p class="text-xs text-neutral-500 mb-3">{body.description}</p>
                  <div class="pt-3 border-t border-neutral-200">
                    <p class="text-xs font-semibold text-neutral-700 mb-1">Registered Members:</p>
                    <ul class="text-xs text-neutral-600 space-y-1">
                      {body.members.map((member) => (
                        <li class="flex items-center">
                          <svg class="w-3 h-3 text-secondary-600 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                          </svg>
                          {member}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Compliance Standards -->
    <section class="section bg-white">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="heading-2 mb-4">Regulatory Compliance</h2>
          <p class="text-lead max-w-2xl mx-auto">
            Full compliance with South African health, safety, and environmental legislation.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto">
          {complianceStandards.map((standard) => (
            <div class="card text-center">
              <div class="w-16 h-16 bg-secondary-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <h3 class="heading-3 mb-2">{standard.title}</h3>
              <p class="text-sm font-semibold text-primary-600 mb-3">{standard.reference}</p>
              <p class="text-body text-sm">{standard.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Team Certifications -->
    <section class="section bg-neutral-50">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="heading-2 mb-4">Team Qualifications & Certifications</h2>
          <p class="text-lead max-w-2xl mx-auto">
            Our team holds extensive qualifications across all aspects of SHEQ management.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {certifications.map((cert) => (
            <div class="card">
              <h3 class="font-semibold text-neutral-900 mb-4 pb-3 border-b border-neutral-200">
                {cert.category}
              </h3>
              <ul class="space-y-2">
                {cert.items.map((item) => (
                  <li class="flex items-start text-sm text-neutral-700">
                    <svg class="w-4 h-4 text-secondary-600 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Industry Expertise -->
    <section class="section bg-white">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="heading-2 mb-4">Industry Expertise</h2>
          <p class="text-lead max-w-2xl mx-auto">
            Proven experience across diverse industries with specialized knowledge and practical application.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {expertise.map((exp) => (
            <div class="card">
              <div class="flex items-start space-x-4">
                <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-neutral-900 mb-2">{exp.area}</h3>
                  <p class="text-sm text-neutral-600">{exp.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Commitment Section -->
    <section class="section bg-primary-50">
      <div class="container">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-8">
            <h2 class="heading-2 mb-4">Our Commitment to Excellence</h2>
          </div>
          
          <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-white rounded-lg p-6 text-center">
              <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-6 h-6 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <h3 class="font-semibold text-neutral-900 mb-2">Continuous Professional Development</h3>
              <p class="text-sm text-neutral-600">
                Regular training and certification updates to maintain industry-leading expertise
              </p>
            </div>

            <div class="bg-white rounded-lg p-6 text-center">
              <div class="w-12 h-12 bg-secondary-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-6 h-6 text-secondary-600" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
                  <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm9.707 5.707a1 1 0 00-1.414-1.414L9 12.586l-1.293-1.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <h3 class="font-semibold text-neutral-900 mb-2">Quality Assurance</h3>
              <p class="text-sm text-neutral-600">
                Rigorous internal audits and quality control processes for all deliverables
              </p>
            </div>

            <div class="bg-white rounded-lg p-6 text-center">
              <div class="w-12 h-12 bg-accent-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-6 h-6 text-accent-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 1.414L10.586 9H7a1 1 0 100 2h3.586l-1.293 1.293a1 1 0 101.414 1.414l3-3a1 1 0 000-1.414z" clip-rule="evenodd" />
                </svg>
              </div>
              <h3 class="font-semibold text-neutral-900 mb-2">Ethical Practice</h3>
              <p class="text-sm text-neutral-600">
                Adherence to professional codes of conduct and ethical business practices
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section section">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="heading-2 mb-4">Work With Certified SHEQ Professionals</h2>
          <p class="cta-text text-lead mb-8">
            Partner with a fully registered, compliant, and experienced SHEQ consulting firm. 
            Get started with a free consultation today.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <Button href="/contact" variant="accent" size="lg">
              Get Free Consultation
            </Button>
            <Button href="/about" variant="outline" size="lg" class="cta-button-outline">
              Meet Our Team
            </Button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
