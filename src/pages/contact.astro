---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import contactData from '../data/contact.json';
---

<Layout 
  title="Contact AE SHEQ Consulting - Get Your Free Consultation"
  description="Contact AE SHEQ Consulting for professional SHEQ services. Located in Mokopane, Limpopo. Call +27 60 644 5032 or email info@aesheq.co.za for a free consultation."
>
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-primary-900 via-primary-800 to-neutral-900 text-white py-20">
      <div class="container">
        <div class="max-w-3xl">
          <div class="inline-flex items-center px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full text-sm font-semibold mb-6">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Get In Touch
          </div>
          <h1 class="heading-display mb-6">Contact Us</h1>
          <p class="text-lead text-neutral-200">
            Ready to ensure your workplace safety and compliance? Get in touch with our SHEQ experts 
            for a free consultation. We're here to help.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Form & Info Section -->
    <section class="section bg-white">
      <div class="container">
        <div class="grid lg:grid-cols-5 gap-12">
          <!-- Contact Form -->
          <div class="lg:col-span-3">
            <div class="max-w-2xl">
              <h2 class="heading-2 mb-4">Send Us a Message</h2>
              <p class="text-body mb-8">
                Fill out the form below and we'll get back to you within 24 hours. 
                For urgent matters, please call us directly.
              </p>

              <form class="space-y-6" id="contact-form">
                <!-- Name -->
                <div>
                  <label for="name" class="form-label">
                    Full Name <span class="text-red-600">*</span>
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="form-input"
                    placeholder="John Doe"
                  />
                </div>

                <!-- Company -->
                <div>
                  <label for="company" class="form-label">
                    Company / Organization
                  </label>
                  <input
                    type="text"
                    id="company"
                    name="company"
                    class="form-input"
                    placeholder="Your Company Name"
                  />
                </div>

                <!-- Email & Phone -->
                <div class="grid md:grid-cols-2 gap-6">
                  <div>
                    <label for="email" class="form-label">
                      Email Address <span class="text-red-600">*</span>
                    </label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      class="form-input"
                      placeholder="john@example.com"
                    />
                  </div>
                  <div>
                    <label for="phone" class="form-label">
                      Phone Number <span class="text-red-600">*</span>
                    </label>
                    <input
                      type="tel"
                      id="phone"
                      name="phone"
                      required
                      class="form-input"
                      placeholder="+27 60 644 5032"
                    />
                  </div>
                </div>

                <!-- Service Interest -->
                <div>
                  <label for="service" class="form-label">
                    Service Interest
                  </label>
                  <select
                    id="service"
                    name="service"
                    class="form-input"
                  >
                    <option value="">Select a service...</option>
                    <option value="safety-consultation">Safety Consultation & Site Inspection</option>
                    <option value="sherq-management">SHERQ Management Systems</option>
                    <option value="safety-files">Project Health and Safety Files</option>
                    <option value="safety-officers">Safety Officer Placement</option>
                    <option value="environmental">Environmental Compliance</option>
                    <option value="audits">Health & Safety Audits</option>
                    <option value="other">Other / General Inquiry</option>
                  </select>
                </div>

                <!-- Message -->
                <div>
                  <label for="message" class="form-label">
                    Message <span class="text-red-600">*</span>
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    required
                    rows="6"
                    class="form-input"
                    placeholder="Tell us about your project or inquiry..."
                  ></textarea>
                </div>

                <!-- Submit Button -->
                <div>
                  <button type="submit" class="btn btn-primary w-full md:w-auto">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    Send Message
                  </button>
                </div>

                <!-- Success/Error Messages -->
                <div id="form-message" class="hidden"></div>
              </form>
            </div>
          </div>

          <!-- Contact Information -->
          <div class="lg:col-span-2">
            <div class="sticky top-24 space-y-6">
              <!-- Contact Details Card -->
              <div class="card">
                <h3 class="heading-3 mb-6">Contact Information</h3>
                
                <div class="space-y-4">
                  <!-- Address -->
                  <div class="flex items-start space-x-4">
                    <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
                      <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                    </div>
                    <div>
                      <p class="font-semibold text-neutral-900 mb-1">Office Address</p>
                      <p class="text-sm text-neutral-600">
                        {contactData.address.street}<br />
                        {contactData.address.area}<br />
                        {contactData.address.city}, {contactData.address.province}<br />
                        {contactData.address.country}
                      </p>
                    </div>
                  </div>

                  <!-- Phone -->
                  <div class="flex items-start space-x-4">
                    <div class="w-10 h-10 bg-secondary-100 rounded-lg flex items-center justify-center flex-shrink-0">
                      <svg class="w-5 h-5 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                      </svg>
                    </div>
                    <div>
                      <p class="font-semibold text-neutral-900 mb-1">Phone</p>
                      <a href={`tel:${contactData.contact.phone}`} class="text-sm text-primary-600 hover:text-primary-700 font-medium">
                        {contactData.contact.phone}
                      </a>
                    </div>
                  </div>

                  <!-- Email -->
                  <div class="flex items-start space-x-4">
                    <div class="w-10 h-10 bg-accent-100 rounded-lg flex items-center justify-center flex-shrink-0">
                      <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                    </div>
                    <div>
                      <p class="font-semibold text-neutral-900 mb-1">Email</p>
                      <a href={`mailto:${contactData.contact.email}`} class="text-sm text-primary-600 hover:text-primary-700 font-medium block">
                        {contactData.contact.email}
                      </a>
                      <a href={`mailto:${contactData.contact.alternativeEmail}`} class="text-sm text-primary-600 hover:text-primary-700 font-medium block">
                        {contactData.contact.alternativeEmail}
                      </a>
                    </div>
                  </div>

                  <!-- Website -->
                  <div class="flex items-start space-x-4">
                    <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
                      <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                      </svg>
                    </div>
                    <div>
                      <p class="font-semibold text-neutral-900 mb-1">Website</p>
                      <a href={`https://${contactData.contact.website}`} class="text-sm text-primary-600 hover:text-primary-700 font-medium">
                        {contactData.contact.website}
                      </a>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Business Hours Card -->
              <div class="card bg-primary-50 border-2 border-primary-200">
                <h3 class="heading-3 mb-4 text-primary-900">Business Hours</h3>
                <div class="space-y-2 text-sm">
                  <div class="flex justify-between">
                    <span class="font-semibold text-neutral-900">Monday - Friday:</span>
                    <span class="text-neutral-700">8:00 AM - 5:00 PM</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="font-semibold text-neutral-900">Saturday - Sunday:</span>
                    <span class="text-neutral-700">Closed</span>
                  </div>
                  <p class="text-xs text-neutral-600 mt-4 pt-4 border-t border-primary-200">
                    Emergency consultations available by appointment
                  </p>
                </div>
              </div>

              <!-- Registration Card -->
              <div class="card bg-secondary-50 border-2 border-secondary-200">
                <h3 class="heading-3 mb-4 text-secondary-900">Company Registration</h3>
                <div class="space-y-2 text-sm">
                  <div>
                    <p class="font-semibold text-neutral-900">{contactData.company.name}</p>
                    <p class="text-neutral-700">Reg No: {contactData.company.registration}</p>
                  </div>
                  <div class="flex flex-wrap gap-2 mt-4">
                    <span class="badge badge-secondary text-xs">SAIOSH</span>
                    <span class="badge badge-secondary text-xs">SACPCMP</span>
                    <span class="badge badge-secondary text-xs">SAIOH</span>
                    <span class="badge badge-secondary text-xs">ACPM</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Map Section (Placeholder) -->
    <section class="section bg-neutral-50">
      <div class="container">
        <div class="text-center mb-8">
          <h2 class="heading-2 mb-4">Find Us</h2>
          <p class="text-lead max-w-2xl mx-auto">
            Located in Mokopane, Limpopo. Serving clients across South Africa.
          </p>
        </div>
        
        <!-- Map Placeholder -->
        <div class="max-w-5xl mx-auto">
          <div class="bg-neutral-200 rounded-2xl overflow-hidden shadow-lg" style="height: 400px;">
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-100 to-secondary-100">
              <div class="text-center">
                <svg class="w-16 h-16 text-primary-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <p class="text-neutral-700 font-semibold">
                  {contactData.address.street}, {contactData.address.area}
                </p>
                <p class="text-neutral-600">
                  {contactData.address.city}, {contactData.address.province}
                </p>
                <p class="text-sm text-neutral-500 mt-2">
                  Map integration available upon deployment
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="section bg-white">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="heading-2 mb-4">Frequently Asked Questions</h2>
            <p class="text-lead">
              Quick answers to common questions about our services.
            </p>
          </div>

          <div class="space-y-6">
            <div class="card">
              <h3 class="font-semibold text-neutral-900 mb-2">How quickly can you respond to a consultation request?</h3>
              <p class="text-body text-sm">
                We typically respond within 24 hours. For urgent matters, please call us directly at {contactData.contact.phone}.
              </p>
            </div>

            <div class="card">
              <h3 class="font-semibold text-neutral-900 mb-2">Do you provide services outside of Limpopo?</h3>
              <p class="text-body text-sm">
                Yes, we serve clients across South Africa. We've successfully completed projects in Gauteng, KwaZulu-Natal, and other provinces.
              </p>
            </div>

            <div class="card">
              <h3 class="font-semibold text-neutral-900 mb-2">What industries do you specialize in?</h3>
              <p class="text-body text-sm">
                We have extensive experience in construction, mining, municipal infrastructure, agriculture, manufacturing, healthcare, and education sectors.
              </p>
            </div>

            <div class="card">
              <h3 class="font-semibold text-neutral-900 mb-2">Are your consultants registered professionals?</h3>
              <p class="text-body text-sm">
                Yes, all our team members are registered with relevant professional bodies including SAIOSH, SACPCMP, SAIOH, and HPCSA.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section bg-primary-600 text-white">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="heading-2 mb-4">Ready to Get Started?</h2>
          <p class="text-lead mb-8 text-primary-100">
            Don't wait for an incident to happen. Contact us today for a free consultation 
            and take the first step towards a safer, compliant workplace.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <Button href={`tel:${contactData.contact.phone}`} variant="accent" size="lg">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Call Now
            </Button>
            <Button href={`mailto:${contactData.contact.email}`} variant="outline" size="lg" class="!border-white !text-white hover:!bg-white hover:!text-primary-600">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Send Email
            </Button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  // Contact form handling
  const form = document.getElementById('contact-form');
  const formMessage = document.getElementById('form-message');

  if (form && formMessage) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);
      
      // Show loading state
      const submitButton = form.querySelector('button[type="submit"]');
      const originalText = submitButton?.innerHTML;
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.innerHTML = '<svg class="animate-spin h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Sending...';
      }
      
      try {
        // TODO: Replace with actual form submission endpoint
        // For now, simulate success after 1 second
        await new Promise(resolve => setTimeout(resolve, 1000));
        
        // Show success message
        formMessage.className = 'bg-secondary-50 border-2 border-secondary-200 rounded-lg p-4 text-secondary-800';
        formMessage.innerHTML = '<strong>Success!</strong> Your message has been sent. We\'ll get back to you within 24 hours.';
        formMessage.classList.remove('hidden');
        
        // Reset form
        form.reset();
        
        // Hide message after 5 seconds
        setTimeout(() => {
          formMessage.classList.add('hidden');
        }, 5000);
        
      } catch (error) {
        // Show error message
        formMessage.className = 'bg-red-50 border-2 border-red-200 rounded-lg p-4 text-red-800';
        formMessage.innerHTML = '<strong>Error!</strong> Something went wrong. Please try again or contact us directly.';
        formMessage.classList.remove('hidden');
      } finally {
        // Restore button
        if (submitButton && originalText) {
          submitButton.disabled = false;
          submitButton.innerHTML = originalText;
        }
      }
    });
  }
</script>
