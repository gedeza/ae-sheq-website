---
interface Props {
  title: string;
  client: string;
  location: string;
  category: string;
  description: string;
  image: string;
  status?: string;
  scope?: string[];
}

const {
  title,
  client,
  location,
  category,
  description,
  image,
  status,
  scope,
} = Astro.props;

const categoryColors: Record<string, string> = {
  'Agriculture': 'bg-secondary-100 text-secondary-800',
  'Energy & Mining': 'bg-accent-100 text-accent-800',
  'Infrastructure': 'bg-primary-100 text-primary-800',
  'Construction': 'bg-neutral-200 text-neutral-800',
  'Municipal': 'bg-blue-100 text-blue-800',
  'Commercial': 'bg-purple-100 text-purple-800',
  'Manufacturing': 'bg-indigo-100 text-indigo-800',
  'Education': 'bg-green-100 text-green-800',
  'Healthcare': 'bg-red-100 text-red-800',
  'Mining': 'bg-yellow-100 text-yellow-800',
};

const categoryColor = categoryColors[category] || 'bg-neutral-100 text-neutral-800';
---

<div class="card group overflow-hidden">
  <!-- Image -->
  <div class="relative -mx-6 -mt-6 mb-6 overflow-hidden h-48">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/70 via-neutral-900/20 to-transparent"></div>
    
    <!-- Status Badge (if current project) -->
    {status && (
      <div class="absolute top-4 right-4">
        <span class="badge bg-secondary-600 text-white px-3 py-1 text-xs font-semibold">
          {status}
        </span>
      </div>
    )}
    
    <!-- Category Badge -->
    <div class="absolute bottom-4 left-4">
      <span class={`badge ${categoryColor} px-3 py-1 text-xs font-semibold`}>
        {category}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="space-y-3">
    <h3 class="heading-3 group-hover:text-primary-600 transition-colors line-clamp-2">
      {title}
    </h3>

    <div class="flex items-center space-x-4 text-sm text-neutral-600">
      <div class="flex items-center">
        <svg class="w-4 h-4 mr-1 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
        <span class="font-medium">{client}</span>
      </div>
      <div class="flex items-center">
        <svg class="w-4 h-4 mr-1 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span>{location}</span>
      </div>
    </div>

    <p class="text-body text-sm line-clamp-3">
      {description}
    </p>

    {scope && scope.length > 0 && (
      <div class="pt-3 border-t border-neutral-200">
        <h4 class="font-semibold text-neutral-900 text-xs mb-2">Project Scope</h4>
        <ul class="space-y-1">
          {scope.slice(0, 3).map((item) => (
            <li class="text-xs text-neutral-600 flex items-start">
              <svg class="w-3 h-3 text-primary-600 mr-1.5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</div>
