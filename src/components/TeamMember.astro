---
interface Props {
  name: string;
  role: string;
  image: string;
  qualifications: string[];
  registrations: string[];
  experience?: string[];
  email?: string;
}

const {
  name,
  role,
  image,
  qualifications,
  registrations,
  experience,
  email,
} = Astro.props;
---

<div class="card group">
  <!-- Image -->
  <div class="relative mb-6 overflow-hidden rounded-lg">
    <img
      src={image}
      alt={`${name} - ${role}`}
      class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-300"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  </div>

  <!-- Name and Role -->
  <div class="mb-4">
    <h3 class="heading-3 mb-2">{name}</h3>
    <p class="text-primary-600 font-semibold text-sm">{role}</p>
  </div>

  <!-- Qualifications -->
  {qualifications && qualifications.length > 0 && (
    <div class="mb-4">
      <h4 class="font-semibold text-neutral-900 text-sm mb-2">Qualifications</h4>
      <ul class="space-y-1">
        {qualifications.map((qual) => (
          <li class="text-sm text-neutral-600 flex items-start">
            <svg class="w-4 h-4 text-secondary-600 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            {qual}
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- Registrations -->
  {registrations && registrations.length > 0 && (
    <div class="mb-4">
      <h4 class="font-semibold text-neutral-900 text-sm mb-2">Professional Registrations</h4>
      <ul class="space-y-1">
        {registrations.map((reg) => (
          <li class="text-sm text-neutral-600 flex items-start">
            <svg class="w-4 h-4 text-primary-600 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            {reg}
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- Experience -->
  {experience && experience.length > 0 && (
    <div class="mb-4">
      <h4 class="font-semibold text-neutral-900 text-sm mb-2">Experience</h4>
      <ul class="space-y-1">
        {experience.map((exp) => (
          <li class="text-sm text-neutral-600 flex items-start">
            <svg class="w-4 h-4 text-accent-600 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
            </svg>
            {exp}
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- Contact -->
  {email && (
    <div class="mt-6 pt-4 border-t border-neutral-200">
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center text-primary-600 hover:text-primary-700 font-semibold text-sm transition-colors"
      >
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Contact
      </a>
    </div>
  )}
</div>
