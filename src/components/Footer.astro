---
import contactData from '../data/contact.json';

const currentYear = new Date().getFullYear();

const quickLinks = [
  { name: 'Home', href: '/' },
  { name: 'About Us', href: '/about' },
  { name: 'Services', href: '/services' },
  { name: 'Projects', href: '/projects' },
];

const services = [
  { name: 'Safety Consultation', href: '/services#safety' },
  { name: 'SHERQ Management', href: '/services#sherq' },
  { name: 'Environmental Compliance', href: '/services#environment' },
  { name: 'Health & Safety Audits', href: '/services#auditing' },
];

const professionalBodies = [
  'SAIOSH',
  'SACPCMP',
  'SAIOH',
  'ACPM',
  'HPCSA'
];
---

<footer class="bg-neutral-900 text-neutral-300">
  <!-- Main Footer Content -->
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      
      <!-- Company Info -->
      <div class="space-y-4">
        <div>
          <img 
            src="/logo/AE_SHEQ_LOGO.PNG" 
            alt="AE SHEQ Consulting" 
            class="h-10 w-auto brightness-0 invert"
          />
        </div>
        <p class="text-sm text-neutral-400">
          Leading SHEQ solutions for a safer, compliant workplace. Over 3 years of expertise in Safety, Health, Environment & Quality consulting.
        </p>
        <div class="space-y-2 text-sm">
          <p class="font-semibold text-white">Registration No:</p>
          <p class="text-neutral-400">{contactData.company.registration}</p>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-lg mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                class="text-sm text-neutral-400 hover:text-primary-400 transition-colors"
              >
                {link.name}
              </a>
            </li>
          ))}
          <li>
            <a 
              href="/credentials" 
              class="text-sm text-neutral-400 hover:text-primary-400 transition-colors"
            >
              Credentials
            </a>
          </li>
          <li>
            <a 
              href="/contact" 
              class="text-sm text-neutral-400 hover:text-primary-400 transition-colors"
            >
              Contact Us
            </a>
          </li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold text-lg mb-4">Our Services</h3>
        <ul class="space-y-2">
          {services.map((service) => (
            <li>
              <a 
                href={service.href} 
                class="text-sm text-neutral-400 hover:text-primary-400 transition-colors"
              >
                {service.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-white font-semibold text-lg mb-4">Contact Us</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-primary-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-neutral-400">
              {contactData.address.street}<br />
              {contactData.address.area}, {contactData.address.city}
            </span>
          </li>
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-primary-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${contactData.contact.phone}`} class="text-neutral-400 hover:text-primary-400 transition-colors">
              {contactData.contact.phone}
            </a>
          </li>
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-primary-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${contactData.contact.email}`} class="text-neutral-400 hover:text-primary-400 transition-colors">
              {contactData.contact.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Professional Affiliations -->
    <div class="mt-12 pt-8 border-t border-neutral-800">
      <div class="text-center">
        <h4 class="text-white font-semibold text-sm mb-4">Professional Affiliations</h4>
        <div class="flex flex-wrap justify-center gap-4">
          {professionalBodies.map((body) => (
            <span class="badge badge-primary text-xs">
              {body}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-neutral-800">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <p class="text-sm text-neutral-400 text-center md:text-left">
          © {currentYear} {contactData.company.name}. All rights reserved.
        </p>
        <div class="flex items-center space-x-6 text-sm text-neutral-400">
          <span>OHS Act 85 of 1993 Compliant</span>
          <span class="hidden md:inline">|</span>
          <span>NEMA Compliant</span>
        </div>
      </div>
    </div>
  </div>
</footer>
